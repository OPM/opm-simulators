+/**
+ * \file   amgcl/relaxation/dilu.hpp
+ * \brief  Multicolor DILU (diagonal-based ILU) relaxation scheme.
+ *
+ * DILU keeps the sparsity pattern of A and only modifies the diagonal:
+ *   M = (D + L) D^{-1} (D + U),   diag(M) = diag(A),
+ * where L/U are the strict lower/upper parts of A. It is as strong a smoother
+ * as ILU0 but needs only a diagonal of fill, so setup is one pass and the apply
+ * is two sparse triangular solves using the original off-diagonals plus D^{-1}.
+ *
+ * Threading: the unknowns are reordered by a greedy multicolor graph coloring of
+ * the sparsity pattern (rows of one color are mutually non-adjacent, hence
+ * independent). The factorization and the forward/backward solves then need only
+ * `#colors` parallel sweeps (a handful for grid graphs), each sweep being a plain
+ * `omp parallel for`. This mirrors OPM's MultithreadDILU2.
+ *
+ * NOTE: implemented for scalar (1x1) value types — the intended use is the CPR
+ * pressure stage. The arithmetic below assumes commuting scalar values.
+ */
+
+#include <vector>
+#include <memory>
+
+#include <amgcl/backend/interface.hpp>
+#include <amgcl/util.hpp>
+
+namespace amgcl {
+namespace relaxation {
+
+template <class Backend>
+struct dilu {
+    typedef typename Backend::value_type value_type;
+    typedef typename math::scalar_of<value_type>::type scalar_type;
+
+    typedef amgcl::detail::empty_params params;
+
+    template <class Matrix>
+    dilu(const Matrix &A, const params &, const typename Backend::params &)
+    {
+        n = backend::rows(A);
+
+        // --- 1) greedy multicolor coloring of the sparsity pattern ---
+        std::vector<int>    color(n, -1);
+        std::vector<size_t> marker;        // marker[c] == i: color c seen while coloring row i
+        marker.reserve(16);
+        int ncolors = 0;
+        for (size_t i = 0; i < n; ++i) {
+            for (auto a = backend::row_begin(A, i); a; ++a) {
+                ptrdiff_t j = a.col();
+                if (static_cast<size_t>(j) != i && color[j] >= 0)
+                    marker[color[j]] = i;
+            }
+            int c = 0;
+            while (c < ncolors && marker[c] == i) ++c;
+            if (c == ncolors) { marker.push_back(n); ++ncolors; }
+            color[i] = c;
+        }
+
+        // color-order position of each row (defines the L/U split)
+        std::vector<ptrdiff_t> count(ncolors, 0);
+        for (size_t i = 0; i < n; ++i) ++count[color[i]];
+        color_ptr.assign(ncolors + 1, 0);
+        for (int c = 0; c < ncolors; ++c) color_ptr[c + 1] = color_ptr[c] + count[c];
+        color_rows.resize(n);
+        std::vector<ptrdiff_t> cursor(color_ptr.begin(), color_ptr.end() - 1);
+        std::vector<ptrdiff_t> pos(n);     // natural -> color-order position
+        for (size_t i = 0; i < n; ++i) {
+            ptrdiff_t p = cursor[color[i]]++;
+            color_rows[p] = i;
+            pos[i] = p;
+        }
+
+        // --- 2) lower/upper neighbour split in color order + diagonal ---
+        lo_ptr.assign(n + 1, 0);
+        up_ptr.assign(n + 1, 0);
+        for (size_t i = 0; i < n; ++i) {
+            for (auto a = backend::row_begin(A, i); a; ++a) {
+                ptrdiff_t j = a.col();
+                if (static_cast<size_t>(j) == i) continue;
+                if (pos[j] < pos[i]) ++lo_ptr[i + 1]; else ++up_ptr[i + 1];
+            }
+        }
+        for (size_t i = 0; i < n; ++i) { lo_ptr[i + 1] += lo_ptr[i]; up_ptr[i + 1] += up_ptr[i]; }
+        lo_col.resize(lo_ptr[n]); lo_aij.resize(lo_ptr[n]); lo_aji.resize(lo_ptr[n]);
+        up_col.resize(up_ptr[n]); up_aij.resize(up_ptr[n]);
+        diag.assign(n, math::zero<value_type>());
+
+        for (size_t i = 0; i < n; ++i) {
+            ptrdiff_t lp = lo_ptr[i], up = up_ptr[i];
+            for (auto a = backend::row_begin(A, i); a; ++a) {
+                ptrdiff_t j = a.col();
+                value_type v = a.value();
+                if (static_cast<size_t>(j) == i) { diag[i] = v; continue; }
+                if (pos[j] < pos[i]) {
+                    lo_col[lp] = j; lo_aij[lp] = v;
+                    value_type aji = math::zero<value_type>();   // A[j,i] (transpose entry)
+                    for (auto b = backend::row_begin(A, j); b; ++b)
+                        if (b.col() == static_cast<ptrdiff_t>(i)) { aji = b.value(); break; }
+                    lo_aji[lp] = aji;
+                    ++lp;
+                } else {
+                    up_col[up] = j; up_aij[up] = v;
+                    ++up;
+                }
+            }
+        }
+
+        // --- 3) DILU factorization: D_i = A_ii - sum_{j<i} A_ij D_j^{-1} A_ji ---
+        // process colors in order; lower neighbours live in earlier colors and are
+        // already inverted, so each color is one parallel sweep.
+        dinv = diag;
+        for (int c = 0; c + 1 < static_cast<int>(color_ptr.size()); ++c) {
+#pragma omp parallel for
+            for (ptrdiff_t k = color_ptr[c]; k < color_ptr[c + 1]; ++k) {
+                ptrdiff_t i = color_rows[k];
+                value_type d = diag[i];
+                for (ptrdiff_t idx = lo_ptr[i]; idx < lo_ptr[i + 1]; ++idx)
+                    d -= lo_aij[idx] * dinv[lo_col[idx]] * lo_aji[idx];
+                dinv[i] = math::inverse(d);
+            }
+        }
+
+        y.resize(n);
+    }
+
+    // One DILU smoothing step: x += M^{-1} (rhs - A x).
+    template <class Matrix, class VectorRHS, class VectorX, class VectorTMP>
+    void apply_pre(const Matrix &A, const VectorRHS &rhs, VectorX &x, VectorTMP &tmp) const
+    {
+        backend::residual(rhs, A, x, tmp);   // tmp = rhs - A x
+        solve(tmp);                          // y = M^{-1} tmp
+#pragma omp parallel for
+        for (ptrdiff_t i = 0; i < static_cast<ptrdiff_t>(n); ++i) x[i] += y[i];
+    }
+
+    template <class Matrix, class VectorRHS, class VectorX, class VectorTMP>
+    void apply_post(const Matrix &A, const VectorRHS &rhs, VectorX &x, VectorTMP &tmp) const
+    {
+        apply_pre(A, rhs, x, tmp);
+    }
+
+    // As a standalone preconditioner: x = M^{-1} rhs.
+    template <class Matrix, class VectorRHS, class VectorX>
+    void apply(const Matrix &, const VectorRHS &rhs, VectorX &x) const
+    {
+        solve(rhs);
+#pragma omp parallel for
+        for (ptrdiff_t i = 0; i < static_cast<ptrdiff_t>(n); ++i) x[i] = y[i];
+    }
+
+    size_t bytes() const
+    {
+        return sizeof(value_type) * (dinv.size() + diag.size() + lo_aij.size() * 2 + up_aij.size() + y.size())
+             + sizeof(ptrdiff_t) * (color_ptr.size() + color_rows.size()
+                                    + lo_ptr.size() + lo_col.size() + up_ptr.size() + up_col.size());
+    }
+
+private:
+    // y = M^{-1} res, with res indexable; result left in member `y`.
+    template <class VectorRES>
+    void solve(const VectorRES &res) const
+    {
+        const int ncolors = static_cast<int>(color_ptr.size()) - 1;
+        // forward: (D + L) t = res  ->  t_i = D_i^{-1} (res_i - sum_{j<i} A_ij t_j)
+        for (int c = 0; c < ncolors; ++c) {
+#pragma omp parallel for
+            for (ptrdiff_t k = color_ptr[c]; k < color_ptr[c + 1]; ++k) {
+                ptrdiff_t i = color_rows[k];
+                value_type s = res[i];
+                for (ptrdiff_t idx = lo_ptr[i]; idx < lo_ptr[i + 1]; ++idx)
+                    s -= lo_aij[idx] * y[lo_col[idx]];
+                y[i] = dinv[i] * s;
+            }
+        }
+        // backward: (D + U) z = D t  ->  z_i = t_i - D_i^{-1} sum_{j>i} A_ij z_j
+        for (int c = ncolors - 1; c >= 0; --c) {
+#pragma omp parallel for
+            for (ptrdiff_t k = color_ptr[c]; k < color_ptr[c + 1]; ++k) {
+                ptrdiff_t i = color_rows[k];
+                value_type s = math::zero<value_type>();
+                for (ptrdiff_t idx = up_ptr[i]; idx < up_ptr[i + 1]; ++idx)
+                    s += up_aij[idx] * y[up_col[idx]];
+                y[i] -= dinv[i] * s;
+            }
+        }
+    }
+
+    size_t n;
+    std::vector<value_type> diag;   // original diagonal
+    std::vector<value_type> dinv;   // inverse modified diagonal
+    std::vector<ptrdiff_t>  color_ptr;   // ncolors+1
+    std::vector<ptrdiff_t>  color_rows;  // n, rows grouped by color
+    std::vector<ptrdiff_t>  lo_ptr, lo_col;
+    std::vector<value_type> lo_aij, lo_aji;
+    std::vector<ptrdiff_t>  up_ptr, up_col;
+    std::vector<value_type> up_aij;
+    mutable std::vector<value_type> y;   // scratch for the triangular solves
+};
+
+} // namespace relaxation
+} // namespace amgcl
+
+#endif
