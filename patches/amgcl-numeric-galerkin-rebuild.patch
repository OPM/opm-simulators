+                A = C.coarse_operator(*Afine, *P, *R);
                 sort_rows(*A);
+                if (allow_rebuild) build_galerkin_cache(*Afine, *P, *R, *A);
                 AMGCL_TOC("coarse operator");
 
                 return A;
@@ -429,22 +501,34 @@ class amg {
                     AMGCL_TOC("move to backend");
                 }
 
+                const bool dbg = std::getenv("OPM_AMGCL_DBG") != nullptr;
                 if(relax) {
                     AMGCL_TIC("relaxation");
+                    auto rt0 = std::chrono::steady_clock::now();
                     relax = std::make_shared<relax_type>(*A, prm.relax, bprm);
+                    if (dbg) { static bool o=false; if(!o){o=true; std::fprintf(stderr,"[amgcl-patch] relax rebuild %.3f ms (rows=%zu)\n", std::chrono::duration<double,std::milli>(std::chrono::steady_clock::now()-rt0).count(), backend::rows(*A)); } }
                     AMGCL_TOC("relaxation");
                 }
 
                 if (solve) {
                     AMGCL_TIC("coarsest level");
+                    auto st0 = std::chrono::steady_clock::now();
                     solve = Backend::create_solver(A, bprm);
+                    if (dbg) { static bool o=false; if(!o){o=true; std::fprintf(stderr,"[amgcl-patch] coarse direct-solver rebuild %.3f ms (rows=%zu)\n", std::chrono::duration<double,std::milli>(std::chrono::steady_clock::now()-st0).count(), backend::rows(*A)); } }
                     AMGCL_TOC("coarsest level");
                 }
 
                 if (bP && bR) {
                     AMGCL_TIC("coarse operator");
-                    A = C.coarse_operator(*A, *bP, *bR);
-                    sort_rows(*A);
+                    if (gcache) {
+                        // OPM patch: numeric-only re-setup; result already matches the
+                        // first-build coarse sparsity/order, so do NOT sort (would break
+                        // the next level's cached fine-index map).
+                        A = galerkin_numeric(*A);
+                    } else {
+                        A = C.coarse_operator(*A, *bP, *bR);
+                        sort_rows(*A);
+                    }
                     AMGCL_TOC("coarse operator");
                 }
 
